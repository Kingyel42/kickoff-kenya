# ─────────────────────────────────────────────
# KickOff Kenya – Required Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────

# Supabase project URL (found in: Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (found in: Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The public URL of this site (used for auth redirect links)
# In local dev this is typically http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: override auth redirect URL during development
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/dashboard
